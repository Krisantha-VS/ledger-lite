# Neon Postgres
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/ledgerlite?sslmode=require"

# AuthSaas
NEXT_PUBLIC_AUTH_URL="https://auth-saas-rho.vercel.app/api/v1"
NEXT_PUBLIC_AUTH_CLIENT_ID="your-client-id"

# JWT secret (same secret configured in AuthSaas for this app)
AUTH_JWT_SECRET="your-jwt-secret"

# AI Providers (OpenAI = primary for CSV + PDF vision; DeepSeek = CSV fallback)
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""

# Dodo Payments (checkout.js overlay — client-safe public key)
NEXT_PUBLIC_DODO_PAYMENT_KEY=""

# Dodo product IDs (from Dodo dashboard → Products)
DODO_PRODUCT_LITE_MONTHLY=""
DODO_PRODUCT_LITE_ANNUAL=""
DODO_PRODUCT_PRO_MONTHLY=""
DODO_PRODUCT_PRO_ANNUAL=""
DODO_PRODUCT_PRO_FOUNDING=""

# Dodo webhook secret (from Dodo dashboard → Developers → Webhooks)
DODO_WEBHOOK_SECRET=""

# Founding member offer (set to "true" at launch, FOUNDING_MEMBER_MAX defaults to 100)
FOUNDING_MEMBER_ENABLED="false"
FOUNDING_MEMBER_MAX="100"

# Royalda Mail (transactional email)
ROYALDA_MAIL_API_KEY=""
