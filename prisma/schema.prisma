generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Accounts ─────────────────────────────────────────────

model Account {
  id              Int           @id @default(autoincrement())
  userId          String        @db.VarChar(36)
  name            String        @db.VarChar(100)
  type            AccountType   @default(checking)
  currency        String        @default("USD") @db.Char(3)
  startingBalance Decimal       @default(0) @db.Decimal(12, 2)
  colour          String        @default("#6366f1") @db.VarChar(7)
  isArchived      Boolean       @default(false)
  createdAt       DateTime      @default(now())

  transactions    Transaction[] @relation("AccountTransactions")
  transfersIn     Transaction[] @relation("TransferDestination")
  goals           Goal[]

  @@index([userId])
}

enum AccountType {
  checking
  savings
  cash
  credit
  investment
}

// ─── Categories ───────────────────────────────────────────

model Category {
  id        Int          @id @default(autoincrement())
  userId    String       @db.VarChar(36)
  name      String       @db.VarChar(80)
  icon      String       @default("Circle") @db.VarChar(40)
  colour    String       @default("#94a3b8") @db.VarChar(7)
  type      CategoryType @default(expense)
  isSystem  Boolean      @default(false)
  createdAt DateTime     @default(now())

  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
}

enum CategoryType {
  income
  expense
  both
}

// ─── Transactions ─────────────────────────────────────────
// amount is always positive — sign derived from type.
// Transfers: single row on source account, transferToId = destination.

model Transaction {
  id          Int             @id @default(autoincrement())
  userId      String          @db.VarChar(36)
  accountId   Int
  categoryId  Int
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime        @db.Date
  note        String?         @db.VarChar(300)
  isRecurring Boolean         @default(false)
  recurrence  Recurrence?
  nextDue     DateTime?       @db.Date
  transferToId Int?

  account     Account         @relation("AccountTransactions", fields: [accountId], references: [id], onDelete: Restrict)
  transferTo  Account?        @relation("TransferDestination", fields: [transferToId], references: [id], onDelete: SetNull)
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([userId, date])
  @@index([accountId])
  @@index([categoryId])
  @@index([userId, nextDue])
  @@index([userId, deletedAt])
  @@index([userId, categoryId, date])
  @@index([userId, isRecurring])
}

enum TransactionType {
  income
  expense
  transfer
}

enum Recurrence {
  weekly
  monthly
}

// ─── Budgets ──────────────────────────────────────────────

model Budget {
  id         Int      @id @default(autoincrement())
  userId     String   @db.VarChar(36)
  categoryId Int
  amount     Decimal  @db.Decimal(12, 2)
  rollover   Boolean  @default(false)
  period     Period   @default(monthly)
  createdAt  DateTime @default(now())

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
}

enum Period {
  monthly
}

// ─── Audit Log ────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     String   @db.VarChar(36)
  action     String   @db.VarChar(50)   // e.g. "transaction.delete"
  entityType String   @db.VarChar(50)
  entityId   Int
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Subscription ──────────────────────────────────────────

model Subscription {
  id                  Int        @id @default(autoincrement())
  userId              String     @unique @db.VarChar(36)
  plan                PlanType   @default(free)
  status              SubStatus  @default(active)
  billing             String?    @db.VarChar(10)
  email               String?    @db.VarChar(254)
  dodoSubscriptionId  String?    @unique @db.VarChar(100)
  currentPeriodEnd    DateTime?
  lastEventAt         DateTime?
  cancelAtPeriodEnd   Boolean    @default(false)
  gracePeriodEndsAt   DateTime?
  aiImportCount       Int        @default(0)
  aiImportResetAt     DateTime?
  trialEndsAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([userId])
}

model CheckoutIntent {
  id        String   @id @default(cuid())
  userId    String   @db.VarChar(36)
  email     String?  @db.VarChar(254)
  traceId   String   @db.VarChar(36)
  plan      String   @db.VarChar(20)
  billing   String   @db.VarChar(10)
  founding  Boolean  @default(false)
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PaymentEvent {
  id              Int       @id @default(autoincrement())
  traceId         String    @db.VarChar(36)
  provider        String    @default("dodo")
  eventId         String    @unique @db.VarChar(120)
  eventType       String    @db.VarChar(60)
  userId          String?   @db.VarChar(36)
  dodoSubId       String?   @db.VarChar(100)
  receivedAt      DateTime
  processedAt     DateTime?
  processingError String?   @db.Text
  quarantined     Boolean   @default(false)
  payloadHash     String?   @db.VarChar(64)

  @@index([traceId])
  @@index([userId])
}

model EmailLog {
  id               Int       @id @default(autoincrement())
  traceId          String    @db.VarChar(36)
  userId           String    @db.VarChar(36)
  to               String    @db.VarChar(254)
  templateId       String    @db.VarChar(60)
  royaldaMessageId String?   @db.VarChar(120)
  sentAt           DateTime  @default(now())
  deliveredAt      DateTime?
  bouncedAt        DateTime?
  failedAt         DateTime?
  failReason       String?   @db.VarChar(300)

  @@index([traceId])
  @@index([userId])
}

model FoundingCounter {
  id    Int @id @default(1)
  count Int @default(0)
}

enum PlanType {
  free
  lite
  pro
}

enum SubStatus {
  active
  past_due
  canceled
}

// ─── User Settings ────────────────────────────────────────

model UserSettings {
  id            Int      @id @default(autoincrement())
  userId        String   @unique @db.VarChar(36)
  currency      String   @default("USD") @db.Char(3)
  locale        String   @default("en-US") @db.VarChar(10)
  theme         String   @default("system") @db.VarChar(10)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Goals ────────────────────────────────────────────────

model Goal {
  id            Int      @id @default(autoincrement())
  userId        String   @db.VarChar(36)
  accountId     Int?
  name          String   @db.VarChar(100)
  targetAmount  Decimal  @db.Decimal(12, 2)
  targetDate    DateTime? @db.Date
  colour        String   @default("#6366f1") @db.VarChar(7)
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())

  account       Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId])
}
